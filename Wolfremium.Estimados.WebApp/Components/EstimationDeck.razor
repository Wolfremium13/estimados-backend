<div class="glow-card">
    <h3 style="margin-bottom: 0.5rem;">Select Your Card</h3>
    <p style="color: var(--text-gray-muted); font-size: 0.9rem; margin-bottom: 1.5rem;">
        Select a card to submit your estimate. The values are updated and shown in real-time.
    </p>

    <div class="card-grid">
        @foreach (var card in deckCards)
        {
            <div class="estimados-card @(card.IsSpecial ? "special-card" : "") @(SelectedCard == card.Value ? "active-selected" : "")"
                 @onclick="() => SelectCard(card.Value)">
                @card.Value
            </div>
        }
    </div>

    <div style="margin-top: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
        <h4 style="font-size: 1rem; color: var(--text-white); margin-bottom: 1rem; font-weight: 600;">
            Card Guide & Meaning
        </h4>
        <div class="row g-3">
            <div class="col-sm-6 col-md-4">
                <div class="legend-card" style="background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.75rem 1rem; height: 100%;">
                    <div style="font-weight: 700; color: #21d789; margin-bottom: 0.25rem;">1, 2, 3, 5, 8</div>
                    <div style="font-size: 0.8rem; color: var(--text-gray-light);">Story Points. Standard scale representing task size and complexity.</div>
                </div>
            </div>
            <div class="col-sm-6 col-md-4">
                <div class="legend-card" style="background: rgba(239, 68, 68, 0.05); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 8px; padding: 0.75rem 1rem; height: 100%;">
                    <div style="font-weight: 700; color: #ef4444; margin-bottom: 0.25rem;">🪓 Axe</div>
                    <div style="font-size: 0.8rem; color: var(--text-gray-light);">Axe Protocol. Halts voting because the story is too complex or ambiguous.</div>
                </div>
            </div>
            <div class="col-sm-6 col-md-4">
                <div class="legend-card" style="background: rgba(127, 82, 255, 0.05); border: 1px solid rgba(127, 82, 255, 0.2); border-radius: 8px; padding: 0.75rem 1rem; height: 100%;">
                    <div style="font-weight: 700; color: #7f52ff; margin-bottom: 0.25rem;">📊 Diagram</div>
                    <div style="font-size: 0.8rem; color: var(--text-gray-light);">Architecture diagrams, flows, or technical designs are needed.</div>
                </div>
            </div>
            <div class="col-sm-6 col-md-4">
                <div class="legend-card" style="background: rgba(33, 215, 137, 0.05); border: 1px solid rgba(33, 215, 137, 0.2); border-radius: 8px; padding: 0.75rem 1rem; height: 100%;">
                    <div style="font-weight: 700; color: #21d789; margin-bottom: 0.25rem;">🤖 AI</div>
                    <div style="font-size: 0.8rem; color: var(--text-gray-light);">High technical uncertainty; seek AI assistance or prompt generation.</div>
                </div>
            </div>
            <div class="col-sm-6 col-md-4">
                <div class="legend-card" style="background: rgba(248, 152, 32, 0.05); border: 1px solid rgba(248, 152, 32, 0.2); border-radius: 8px; padding: 0.75rem 1rem; height: 100%;">
                    <div style="font-weight: 700; color: #f89820; margin-bottom: 0.25rem;">☕ Coffee Cup</div>
                    <div style="font-size: 0.8rem; color: var(--text-gray-light);">Fatigue or deadlock; take a short team break to rest.</div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? SelectedCard { get; set; }
    [Parameter] public EventCallback<string> OnCardSelected { get; set; }

    private class DeckCard(string value, bool isSpecial)
    {
        public string Value { get; } = value;
        public bool IsSpecial { get; } = isSpecial;
    }

    private readonly List<DeckCard> deckCards = new()
    {
        new("1", false), new("2", false), new("3", false), new("5", false), new("8", false),
        new("Axe", true), new("Diagram", true), new("AI", true), new("Coffee Cup", true)
    };

    private async Task SelectCard(string cardValue)
    {
        await OnCardSelected.InvokeAsync(cardValue);
    }
}
