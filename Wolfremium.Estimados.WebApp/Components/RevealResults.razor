<div class="glow-card"
     style="border-color: @(CurrentSession.CurrentState == "Halted" ? "#ef4444" : (CurrentSession.HasDiscrepancy ? "#f89820" : "#21d789"));">
    @if (CurrentSession.CurrentState == "Halted")
    {
        <div style="text-align: center; padding: 1rem 0;">
            <span style="font-size: 3.5rem; display: block; margin-bottom: 1rem;">🪓</span>
            <h3 style="color: #ef4444; margin-bottom: 0.5rem;">Estimation Halted (Limit of 8 Exceeded)</h3>
            <p style="color: var(--text-gray-light); max-width: 500px; margin: 0 auto; margin-bottom: 1rem;">
                The Axe protocol has been triggered. This story is too complex or ambiguous. It
                must be split into smaller tasks before proceeding.
            </p>
            @if (CurrentSession.Votes != null)
            {
                var axeLaunchers = CurrentSession.Votes
                    .Where(v => string.Equals(v.Card, "Axe", StringComparison.OrdinalIgnoreCase))
                    .Select(v => v.Name)
                    .ToList();
                @if (axeLaunchers.Any())
                {
                    <div style="margin-top: 1.5rem; padding: 0.75rem 1.25rem; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 8px; display: inline-block;">
                        <span style="color: #ef4444; font-weight: 600; font-size: 0.95rem;">
                            🪓 Triggered by: 
                        </span>
                        <span style="color: var(--text-white); font-weight: 700; font-size: 0.95rem;">
                            @string.Join(", ", axeLaunchers)
                        </span>
                    </div>
                }
            }
        </div>
    }
    else if (!CurrentSession.HasDiscrepancy && CurrentSession.ConsensusValue != null)
    {
        <div style="text-align: center; padding: 1rem 0;">
            <span style="font-size: 3.5rem; display: block; margin-bottom: 1.5rem; background: var(--gradient-brand); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 800;">
                @CurrentSession.ConsensusValue
            </span>
            <h3 style="color: #21d789; margin-bottom: 0.5rem;">Consensus Reached!</h3>
            <p style="color: var(--text-gray-light);">
                The team has agreed on an effort score of <strong>@CurrentSession.ConsensusValue</strong> points.
            </p>
        </div>
    }
    else
    {
        <div style="text-align: center; padding: 1rem 0;">
            <span style="font-size: 3.5rem; display: block; margin-bottom: 1rem;">⚖️</span>
            <h3 style="color: #f89820; margin-bottom: 0.5rem;">Discrepancy Detected</h3>
            <p style="color: var(--text-gray-light); max-width: 500px; margin: 0 auto; margin-bottom: 1rem;">
                The votes do not match. The lowest and highest voters should explain their technical
                reasoning.
            </p>
            @if (IsModerator)
            {
                <button class="btn-premium" @onclick="TransitionToConsensus">
                    Move to Consensus Management
                </button>
            }

            <!-- Show Vote Distribution / Analysis -->
            <div style="max-width: 400px; margin: 1.5rem auto 0 auto; text-align: left; background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.25rem;">
                <h4 style="font-size: 0.9rem; font-weight: 600; color: var(--text-white); margin-top: 0; margin-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem;">
                    Vote Distribution
                </h4>
                @{
                    var distribution = GetVoteDistribution();
                    foreach (var kv in distribution)
                    {
                        var percentage = (double)kv.Value / CurrentSession.Votes.Count * 100;
                        <div style="margin-bottom: 0.75rem;">
                            <div style="display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 0.25rem;">
                                <span style="font-weight: 600; color: #7f52ff;">Card @kv.Key</span>
                                <span style="color: var(--text-gray-muted);">@kv.Value @(kv.Value == 1 ? "vote" : "votes") (@($"{percentage:F0}%"))</span>
                            </div>
                            <div style="height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden;">
                                <div style="height: 100%; width: @($"{percentage}%"); background: var(--gradient-brand); border-radius: 3px;"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }

    <!-- Flagged Special Cards Recommendation -->
    @if (CurrentSession.FlaggedSpecialCards != null && CurrentSession.FlaggedSpecialCards.Any())
    {
        <div style="margin-top: 2rem; border-top: 1px dashed var(--border-color); padding-top: 1.5rem;">
            <h4 style="font-size: 1rem; margin-bottom: 0.75rem; text-transform: uppercase; color: var(--text-gray-muted); letter-spacing: 0.05em;">
                Flagged Actions:
            </h4>
            <div class="d-flex gap-2 flex-wrap">
                @foreach (var sc in CurrentSession.FlaggedSpecialCards)
                {
                    <span style="background: rgba(127, 82, 255, 0.1); color: #7f52ff; border: 1px solid rgba(127, 82, 255, 0.2); padding: 6px 12px; border-radius: 20px; font-size: 0.85rem; font-weight: 600;">
                        @if (sc == "Diagram")
                        {
                            <span>🎨 Sketch Architecture (Diagram)</span>
                        }
                        else if (sc == "AI")
                        {
                            <span>🤖 Candidates for AI Automation</span>
                        }
                        else if (sc == "Coffee Cup")
                        {
                            <span>☕ Take a coffee break</span>
                        }
                        else if (sc == "Axe")
                        {
                            <span>🪓 Axe Protocol (Too complex)</span>
                        }
                        else
                        {
                            <span>@sc</span>
                        }
                    </span>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public EstimationSessionDto CurrentSession { get; set; } = null!;
    [Parameter] public bool IsModerator { get; set; }
    [Parameter] public EventCallback OnTransitionToConsensus { get; set; }

    private async Task TransitionToConsensus()
    {
        await OnTransitionToConsensus.InvokeAsync();
    }

    private Dictionary<string, int> GetVoteDistribution()
    {
        var dist = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        if (CurrentSession.Votes == null) return dist;

        foreach (var v in CurrentSession.Votes)
        {
            if (string.IsNullOrEmpty(v.Card)) continue;
            dist[v.Card] = dist.GetValueOrDefault(v.Card, 0) + 1;
        }

        return dist.OrderByDescending(kv => kv.Value).ToDictionary(kv => kv.Key, kv => kv.Value);
    }
}
