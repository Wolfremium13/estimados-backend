@page "/room/{RoomId:guid}"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using System.Net
@using System.Web
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable

<PageTitle>Room Dashboard - es-timados</PageTitle>

@if (connectionState == State.Connecting)
{
    <div class="text-center" style="margin-top: 5rem;">
        <div class="spinner-border text-primary" role="status"
             style="width: 3rem; height: 3rem; color: #7f52ff !important;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p style="color: var(--text-gray-light); margin-top: 1.5rem; font-size: 1.1rem;">Connecting to room
            session...</p>
    </div>
}
else if (connectionState == State.WaitingForApproval)
{
    <div class="row justify-content-center" style="margin-top: 5rem;">
        <div class="col-md-6 text-center">
            <div class="glow-card">
                <div class="loading-progress"
                     style="position: relative; margin: 0 auto 2rem auto; width: 5rem; height: 5rem; border: 4px solid var(--border-color); border-top: 4px solid #21d789; border-radius: 50%; animation: spin 1s linear infinite;"></div>
                <h3 style="margin-bottom: 1rem;">Waiting for Approval</h3>
                <p style="color: var(--text-gray-light); font-size: 1rem; line-height: 1.6;">
                    Hi <strong>@ParticipantName</strong>, your request to join as <strong>@ParticipantRole</strong> has
                    been submitted.
                </p>
                <p style="color: var(--text-gray-muted); font-size: 0.9rem;">
                    Please wait until the Moderator approves your access.
                </p>
            </div>
        </div>
    </div>

    <style>
        @@keyframes spin {
            0% {
                transform: rotate(0deg);
            }
            100% {
                transform: rotate(360deg);
            }
        }
    </style>
}
else if (connectionState == State.Rejected)
{
    <div class="row justify-content-center" style="margin-top: 5rem;">
        <div class="col-md-6 text-center">
            <div class="glow-card" style="border-color: #ef4444;">
                <span style="font-size: 3rem; color: #ef4444; display: block; margin-bottom: 1rem;">❌</span>
                <h3 style="margin-bottom: 1rem; color: #ef4444;">Access Denied</h3>
                <p style="color: var(--text-gray-light); font-size: 1rem; margin-bottom: 2rem;">
                    The Moderator has rejected your request to join this room.
                </p>
                <button class="btn-premium" @onclick="GoHome">Return Home</button>
            </div>
        </div>
    </div>
}
else if (connectionState == State.Disconnected)
{
    <div class="row justify-content-center" style="margin-top: 5rem;">
        <div class="col-md-6 text-center">
            <div class="glow-card" style="border-color: #62626c;">
                <span style="font-size: 3rem; color: var(--text-gray-muted); display: block; margin-bottom: 1rem;">🔌</span>
                <h3 style="margin-bottom: 1rem; color: var(--text-gray-light);">Session Closed</h3>
                <p style="color: var(--text-gray-light); font-size: 1rem; margin-bottom: 2rem;">
                    The room was closed or the Moderator disconnected.
                </p>
                <button class="btn-premium" @onclick="GoHome">Return Home</button>
            </div>
        </div>
    </div>
}
else if (connectionState == State.Connected)
{
    <div class="row g-4">
        <!-- Top Info Header -->
        <div class="col-12">
            <div class="glow-card" style="padding: 1.5rem 2rem;">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <span class="step-badge"
                              style="display: inline-flex; align-items: center; gap: 8px; vertical-align: middle;">
                            Room Code: @RoomId.ToString().Substring(0, 8)...
                            <button @onclick="CopyRoomIdToClipboard"
                                    style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #21d789; cursor: pointer; font-size: 0.7rem; padding: 2px 8px; border-radius: 4px; font-weight: 700; font-family: var(--font-sans); margin-left: 4px; transition: var(--transition-smooth);"
                                    title="Copy Full Room Code">
                                @copyButtonText
                            </button>
                        </span>
                        <div class="user-story-description" style="margin-top: 0.5rem; margin-bottom: 0; font-size: 1.1rem; line-height: 1.6; color: var(--text-gray-light);">
                            @if (string.IsNullOrEmpty(currentSession?.StoryDescription))
                            {
                                <h2 style="margin: 0; font-size: 1.5rem;">Waiting for story...</h2>
                            }
                            else
                            {
                                @((MarkupString)Markdown.ToHtml(currentSession.StoryDescription))
                            }
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <span class="step-badge @(currentSession?.CurrentState == "PrivateEstimation" ? "" : "inactive")">
                            Voting State: @(currentSession?.CurrentState ?? "Not Started")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Left Column: Main Interactive Panels -->
        <div class="col-md-8">
            <!-- Moderator Control Panel -->
            @if (IsModerator)
            {
                <div class="glow-card" style="margin-bottom: 2rem; border-color: rgba(33, 215, 137, 0.3);">
                    <h3 style="margin-bottom: 1rem; color: #21d789; font-size: 1.25rem;">Moderator Controls</h3>

                    @if (currentSession == null)
                    {
                        <div class="form-group" style="margin-bottom: 1rem;">
                            <label class="form-label" for="storyDesc">User Story Description / Title (supports Markdown)</label>
                            <textarea id="storyDesc" class="form-control" rows="5"
                                      placeholder="e.g.&#10;# User Story Title&#10;As a user...&#10;I want to...&#10;So that...&#10;&#10;### Acceptance Criteria&#10;- [ ] Criteria 1&#10;- [ ] Criteria 2"
                                      @bind="newStoryDescription" @bind:event="oninput"
                                      style="resize: vertical; font-family: monospace;"></textarea>
                        </div>
                        <button class="btn-premium @(string.IsNullOrWhiteSpace(newStoryDescription) ? "disabled" : "")" @onclick="StartSession"
                                disabled="@(string.IsNullOrWhiteSpace(newStoryDescription))">
                            Start Estimation Session
                        </button>
                    }
                    else
                    {
                        <div class="d-flex gap-2 flex-wrap">
                            @if (currentSession.CurrentState == "StoryPresentation")
                            {
                                <button class="btn-premium" @onclick="TransitionToPrivate">Open Voting (Private)</button>
                            }
                            else if (currentSession.CurrentState == "PrivateEstimation")
                            {
                                var developers = roomParticipants.Where(p => string.Equals(p.Role, "Developer", StringComparison.OrdinalIgnoreCase)).ToList();
                                var allDevelopersVoted = developers.Any() && developers.All(dev => votedParticipants.Contains(dev.Name));
                                <button class="btn-premium @(!allDevelopersVoted ? "disabled" : "")" @onclick="RevealVotes"
                                        disabled="@(!allDevelopersVoted)">Reveal Votes
                                </button>
                            }
                            else if (currentSession.CurrentState is "SimultaneousReveal" or "ConsensusManagement" or "Halted")
                            {
                                <button class="btn-premium" @onclick="RestartVotes">Restart Voting Round</button>
                                <button class="btn-outline-premium" @onclick="CloseSession">New Story</button>
                            }
                        </div>
                    }
                </div>
            }

            <!-- Estimation Deck (Only visible to Developers when in PrivateEstimation state) -->
            @if (ParticipantRole == "Developer" && currentSession?.CurrentState == "PrivateEstimation")
            {
                <EstimationDeck SelectedCard="@selectedCard" OnCardSelected="CastVote" />
            }

            <!-- Reveal Session Summary Results -->
            @if (currentSession?.CurrentState is "SimultaneousReveal" or "ConsensusManagement" or "Halted")
            {
                <RevealResults CurrentSession="currentSession" IsModerator="@IsModerator" OnTransitionToConsensus="TransitionToConsensus" />
            }
        </div>

        <!-- Right Column: Room participants and Join Requests -->
        <div class="col-md-4">
            <!-- Join Requests (Only visible to Moderator) -->
            @if (IsModerator && pendingRequests.Any())
            {
                <PendingRequestsList PendingRequests="@pendingRequests"
                                     OnApprove="ApproveRequest"
                                     OnReject="RejectRequest" />
            }

            <!-- Participants list / Votes state -->
            <ParticipantList RoomParticipants="roomParticipants"
                             CurrentSession="currentSession"
                             ParticipantOnlineStatus="participantOnlineStatus"
                             VotedParticipants="votedParticipants" />
        </div>
    </div>
}

@code {
    [Parameter] public Guid RoomId { get; set; }

    private string ParticipantName = string.Empty;
    private string ParticipantRole = string.Empty;
    private string RequestIdStr = string.Empty;
    private Guid? RequestId;
    private string copyButtonText = "Copy Code";

    private bool IsModerator => ParticipantRole == "Moderator";

    private State connectionState = State.Connecting;
    private HubConnection? hubConnection;
    private EstimationSessionDto? currentSession;
    private string? selectedCard;
    private string newStoryDescription = string.Empty;
    private HashSet<string> votedParticipants = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, bool> participantOnlineStatus = new(StringComparer.OrdinalIgnoreCase);
    private List<PendingRequestModel> pendingRequests = new();

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = HttpUtility.ParseQueryString(uri.Query);
        ParticipantName = query["name"] ?? string.Empty;
        ParticipantRole = query["role"] ?? string.Empty;
        RequestIdStr = query["requestId"] ?? string.Empty;

        if (string.IsNullOrEmpty(ParticipantName) || string.IsNullOrEmpty(ParticipantRole))
        {
            Navigation.NavigateTo($"/?roomCode={RoomId}");
            return;
        }

        if (Guid.TryParse(RequestIdStr, out var reqId))
        {
            RequestId = reqId;
        }

        // Initialize state
        connectionState = IsModerator ? State.Connected : State.WaitingForApproval;

        // Connect to SignalR
        hubConnection = new HubConnectionBuilder()
                .WithUrl("http://localhost:5011/hubs/room")
                .WithAutomaticReconnect()
                .Build();

        hubConnection.Reconnected += async (connectionId) =>
        {
            if (IsModerator)
            {
                await hubConnection.InvokeAsync("JoinRoomAsModerator", RoomId);
            }
            else
            {
                await hubConnection.InvokeAsync("JoinRoomAsParticipantWithName", RoomId, ParticipantName);
            }
        };

        // Register handlers
        hubConnection.On<string, bool>("OnParticipantConnectionStatusChanged", (name, isOnline) =>
        {
            participantOnlineStatus[name] = isOnline;
            StateHasChanged();
        });

        hubConnection.On<Guid, string, string>("OnJoinRequestReceived", (reqId, name, role) =>
        {
            if (IsModerator)
            {
                pendingRequests.Add(new PendingRequestModel(reqId, name, role));
                StateHasChanged();
            }
        });

        hubConnection.On<Guid>("OnJoinRequestApproved", async (reqId) =>
        {
            if (!IsModerator && RequestId == reqId)
            {
                connectionState = State.Connected;
            }

            if (connectionState == State.Connected)
            {
                await FetchSession();
                await FetchRoomParticipants();
                StateHasChanged();
            }
        });

        hubConnection.On<Guid>("OnJoinRequestRejected", (reqId) =>
        {
            if (!IsModerator && RequestId == reqId)
            {
                connectionState = State.Rejected;
                StateHasChanged();
            }
        });

        hubConnection.On("OnRoomClosed", () =>
        {
            if (!IsModerator)
            {
                connectionState = State.Disconnected;
                StateHasChanged();
            }
        });

        hubConnection.On<string>("OnVoteCast", async (name) =>
        {
            votedParticipants.Add(name);
            await FetchSession();
            StateHasChanged();
        });

        hubConnection.On<EstimationSessionDto>("OnVotesRevealed", (dto) =>
        {
            currentSession = dto;
            selectedCard = null; // Clear chosen card on reveal
            StateHasChanged();
        });

        hubConnection.On<string>("OnSessionHalted", (reason) =>
        {
            if (currentSession != null)
            {
                currentSession = currentSession with { CurrentState = "Halted" };
            }

            StateHasChanged();
        });

        hubConnection.On("OnVotesRestarted", async () =>
        {
            votedParticipants.Clear();
            selectedCard = null;
            await FetchSession();
            StateHasChanged();
        });

        hubConnection.On("OnSessionUpdated", async () =>
        {
            await FetchSession();
            await FetchRoomParticipants();
            StateHasChanged();
        });

        try
        {
            await hubConnection.StartAsync();

            if (IsModerator)
            {
                await hubConnection.InvokeAsync("JoinRoomAsModerator", RoomId);
                await FetchSession();
                await FetchRoomParticipants();
            }
            else
            {
                await hubConnection.InvokeAsync("JoinRoomAsParticipantWithName", RoomId, ParticipantName);

                await FetchRoomParticipants();
                var isAlreadyApproved = roomParticipants.Any(p => string.Equals(p.Name, ParticipantName, StringComparison.OrdinalIgnoreCase));
                if (isAlreadyApproved)
                {
                    connectionState = State.Connected;
                    await FetchSession();
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Hub connection error: {ex.Message}");
        }
    }

    private async Task FetchSession()
    {
        int retries = 5;
        int delayMs = 300;

        for (int i = 0; i < retries; i++)
        {
            try
            {
                var response = await Http.GetAsync($"v1/rooms/{RoomId}/session");
                if (response.StatusCode == HttpStatusCode.NoContent)
                {
                    currentSession = null;
                    return; // Success (no session active yet)
                }
                else if (response.IsSuccessStatusCode)
                {
                    var session = await response.Content.ReadFromJsonAsync<EstimationSessionDto>();
                    if (session != null)
                    {
                        currentSession = session;
                        votedParticipants.Clear();
                        if (currentSession.Votes != null)
                        {
                            foreach (var v in currentSession.Votes)
                            {
                                votedParticipants.Add(v.Name);
                            }
                        }

                        if (currentSession.CurrentState == "PrivateEstimation" && !votedParticipants.Contains(ParticipantName))
                        {
                            selectedCard = null;
                        }

                        return; // Success
                    }
                }
                else if (response.StatusCode == HttpStatusCode.NotFound)
                {
                    Console.WriteLine($"Session/Room {RoomId} not found (attempt {i + 1}/{retries}). Retrying in {delayMs}ms...");
                    if (i == retries - 1)
                    {
                        RedirectToHomeReset();
                        return;
                    }
                }
                else
                {
                    Console.WriteLine($"Error response {response.StatusCode} (attempt {i + 1}/{retries}). Retrying...");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Exception fetching session (attempt {i + 1}/{retries}): {ex.Message}");
            }

            if (i < retries - 1)
            {
                await Task.Delay(delayMs);
            }
        }

        currentSession = null;
    }

    private List<ParticipantDto> roomParticipants = new();

    private async Task FetchRoomParticipants()
    {
        int retries = 5;
        int delayMs = 300;

        for (int i = 0; i < retries; i++)
        {
            try
            {
                var response = await Http.GetAsync($"v1/rooms/{RoomId}/participants");
                if (response.IsSuccessStatusCode)
                {
                    var participants = await response.Content.ReadFromJsonAsync<List<ParticipantDto>>();
                    if (participants != null)
                    {
                        roomParticipants = participants;
                        foreach (var p in participants)
                        {
                            if (!participantOnlineStatus.ContainsKey(p.Name))
                            {
                                participantOnlineStatus[p.Name] = true;
                            }
                        }
                        return; // Success!
                    }
                }
                else if (response.StatusCode == HttpStatusCode.NotFound)
                {
                    Console.WriteLine($"Room {RoomId} not found (attempt {i + 1}/{retries}). Retrying in {delayMs}ms...");
                    if (i == retries - 1)
                    {
                        RedirectToHomeReset();
                        return;
                    }
                }
                else
                {
                    Console.WriteLine($"Error response {response.StatusCode} (attempt {i + 1}/{retries}). Retrying...");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Exception fetching participants (attempt {i + 1}/{retries}): {ex.Message}");
            }

            if (i < retries - 1)
            {
                await Task.Delay(delayMs);
            }
        }
    }

    private async Task StartSession()
    {
        if (string.IsNullOrWhiteSpace(newStoryDescription)) return;

        try
        {
            var response = await Http.PostAsJsonAsync($"v1/rooms/{RoomId}/session/start", new { StoryDescription = newStoryDescription });
            if (response.IsSuccessStatusCode)
            {
                newStoryDescription = string.Empty;
                await FetchSession();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error starting session: {ex.Message}");
        }
    }

    private async Task TransitionToPrivate()
    {
        try
        {
            var response = await Http.PostAsync($"v1/rooms/{RoomId}/session/transition/private", null);
            if (response.IsSuccessStatusCode)
            {
                await hubConnection!.InvokeAsync("RestartEstimation", RoomId);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error transitioning: {ex.Message}");
        }
    }

    private async Task TransitionToConsensus()
    {
        try
        {
            var response = await Http.PostAsync($"v1/rooms/{RoomId}/session/transition/consensus", null);
            if (response.IsSuccessStatusCode)
            {
                await FetchSession();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error transitioning: {ex.Message}");
        }
    }

    private async Task CastVote(string card)
    {
        if (hubConnection == null || selectedCard == card) return;

        try
        {
            selectedCard = card;
            await hubConnection.InvokeAsync("CastVote", RoomId, ParticipantName, card);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error casting vote: {ex.Message}");
        }
    }

    private async Task RevealVotes()
    {
        if (hubConnection == null) return;

        try
        {
            await hubConnection.InvokeAsync("RevealVotes", RoomId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error revealing: {ex.Message}");
        }
    }

    private async Task RestartVotes()
    {
        if (hubConnection == null) return;

        try
        {
            var response = await Http.PostAsync($"v1/rooms/{RoomId}/session/transition/private", null);
            if (response.IsSuccessStatusCode)
            {
                await hubConnection.InvokeAsync("RestartEstimation", RoomId);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error restarting: {ex.Message}");
        }
    }

    private async Task CloseSession()
    {
        try
        {
            var response = await Http.PostAsync($"v1/rooms/{RoomId}/session/close", null);
            if (response.IsSuccessStatusCode)
            {
                currentSession = null;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error closing session: {ex.Message}");
        }
    }

    private async Task ApproveRequest(Guid reqId)
    {
        try
        {
            var response = await Http.PostAsync($"v1/rooms/{RoomId}/join-requests/{reqId}/approve", null);
            if (response.IsSuccessStatusCode)
            {
                pendingRequests.RemoveAll(r => r.RequestId == reqId);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error approving request: {ex.Message}");
        }
    }

    private async Task RejectRequest(Guid reqId)
    {
        try
        {
            var response = await Http.PostAsync($"v1/rooms/{RoomId}/join-requests/{reqId}/reject", null);
            if (response.IsSuccessStatusCode)
            {
                pendingRequests.RemoveAll(r => r.RequestId == reqId);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error rejecting request: {ex.Message}");
        }
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/");
    }

    private async Task CopyRoomIdToClipboard()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", RoomId.ToString());
            copyButtonText = "Copied!";
            StateHasChanged();
            await Task.Delay(2000);
            copyButtonText = "Copy Code";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Clipboard error: {ex.Message}");
        }
    }

    private void RedirectToHomeReset()
    {
        Navigation.NavigateTo("/?error=memory_reset");
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection != null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private enum State
    {
        Connecting,
        WaitingForApproval,
        Rejected,
        Connected,
        Disconnected
    }



}
